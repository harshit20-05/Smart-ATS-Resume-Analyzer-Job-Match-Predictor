    with col_results:
        st.subheader("Step 2: Analysis Results")
        if btn_predict:
            # Preprocess numericals using saved scalers
            # Age: MinMaxScaler, Frequency: StandardScaler, Similarity: MinMaxScaler
            scaled_age = assets["age_scaler"].transform([[user_age]])[0][0]
            scaled_freq = assets["freq_scaler"].transform([[user_freq]])[0][0]
            # Since similarity scaler in train used MinMaxScaler:
            scaled_sim = user_sim # similarity is already between 0 and 1, we can pass directly
            
            # Preprocess text (clean & TF-IDF)
            cleaned_t = clean_text_local(user_comment)
            tfidf_feat = assets["tfidf"].transform([cleaned_t]).toarray()
            
            # 1. Prediction using Naive Bayes text model
            nb_pred = assets["naive_bayes"].predict(tfidf_feat)[0]
            nb_prob = assets["naive_bayes"].predict_proba(tfidf_feat)[0][1]
            
            # 2. Prediction using Logistic Regression metadata model
            meta_features = np.array([[scaled_age, scaled_freq, user_sim]])
            lr_pred = assets["logistic"].predict(meta_features)[0]
            lr_prob = assets["logistic"].predict_proba(meta_features)[0][1]
            
            # Display findings visually
            st.markdown("#### Classifier Confidences:")
            
            # Naive Bayes
            nb_color = "red" if nb_pred == 1 else "green"
            nb_label = "IT CELL / BOT" if nb_pred == 1 else "HUMAN"
            st.markdown(f"**Naive Bayes (Text Model)**: <span style='color:{nb_color}; font-weight:bold'>{nb_label}</span> (Spam Probability: `{nb_prob:.2%}`)", unsafe_allow_html=True)
            st.progress(float(nb_prob))
            
            # Logistic Regression
            lr_color = "red" if lr_pred == 1 else "green"
            lr_label = "IT CELL / BOT" if lr_pred == 1 else "HUMAN"
            st.markdown(f"**Logistic Regression (Metadata Model)**: <span style='color:{lr_color}; font-weight:bold'>{lr_label}</span> (Spam Probability: `{lr_prob:.2%}`)", unsafe_allow_html=True)
            st.progress(float(lr_prob))
            
            # final conclusion card
            st.markdown("---")
            if lr_prob > 0.5 and nb_prob > 0.5:
                st.error("🚨 HIGH ALERT: Both models confirm this comment is a coordinated bot campaign!")
            elif lr_prob > 0.5 or nb_prob > 0.5:
                st.warning("⚠️ WARNING: Suspected bot behavior detected (anomaly in either text style or meta logs).")
            else:

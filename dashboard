# Helper function to load model assets safely
@st.cache_resource
def load_assets():
    try:
        logistic_model = joblib.load("models_saved/logistic_regression_model.joblib")
        nb_model = joblib.load("models_saved/naive_bayes_model.joblib")
        kmeans_model = joblib.load("models_saved/kmeans_model.joblib")
        tfidf_vec = joblib.load("models_saved/tfidf_vectorizer.joblib")
        pca_model = joblib.load("models_saved/pca_model.joblib")
        age_scaler = joblib.load("models_saved/age_scaler.joblib")
        freq_scaler = joblib.load("models_saved/freq_scaler.joblib")
        simple_reg = joblib.load("models_saved/simple_regression_model.joblib")
        multi_reg = joblib.load("models_saved/multiple_regression_model.joblib")
        return {
            "logistic": logistic_model,
            "naive_bayes": nb_model,
            "kmeans": kmeans_model,
            "tfidf": tfidf_vec,
            "pca": pca_model,
            "age_scaler": age_scaler,
            "freq_scaler": freq_scaler,
            "simple_reg": simple_reg,
            "multi_reg": multi_reg,
            "loaded": True
        }
    except Exception as e:
        return {"loaded": False, "error": str(e)}

# Local text cleaning helper
def clean_text_local(text):
    import re
    if not isinstance(text, str): return ""
    text = text.lower()
    text = re.sub(r'https?://\S+|www\.\S+', '', text)
    text = re.sub(r'[^a-zA-Z\s#]', '', text)
    text = re.sub(r'\s+', ' ', text).strip()
    return text


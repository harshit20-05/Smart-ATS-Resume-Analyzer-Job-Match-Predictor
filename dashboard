        )
        user_age = st.slider("Account Age (in days)", 1, 3000, 15)
        user_freq = st.slider("Posting Frequency (per minute)", 0.05, 50.0, 15.0, 0.1)
        user_sim = st.slider("Similarity to Template Campaign (0.0 - 1.0)", 0.0, 1.0, 0.85, 0.05)
        
